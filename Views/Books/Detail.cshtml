@model BookListItemViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="page-header">
    <div>
        <h2 class="page-title">@Model.Title</h2>
        <p class="page-description">Chi tiết sách</p>
    </div>
    <a class="btn btn-light" asp-controller="Books" asp-action="Index">Quay lại</a>
</div>

<div class="product-card" style="max-width:500px">
    <p class="product-meta"><strong>Mã Sách:</strong> @Model.BookCode</p>
    <p class="product-meta"><strong>Tác Giả:</strong> @Model.Author</p>
    <p class="product-meta"><strong>Thể Loại:</strong> @Model.GenreName</p>
    <p class="product-price">@Model.Price.ToString("N0") VNĐ</p>
    <p class="product-meta"><strong>Tồn Kho:</strong>
        @if (Model.Quantity == 0)
        {
            <span class="badge badge-danger">Hết hàng</span>
        }
        else if (Model.IsLowStock)
        {
            <span class="badge badge-warning">@Model.Quantity (tồn kho thấp)</span>
        }
        else
        {
            <span class="badge badge-success">@Model.Quantity</span>
        }
    </p>
    <div class="card-actions">
        <a class="btn" asp-controller="Sales" asp-action="Create">Bán Sách Này</a>
    </div>
</div>
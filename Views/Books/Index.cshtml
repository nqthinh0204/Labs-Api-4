@model List<BookListItemViewModel>
@{
    ViewData["Title"] = "Danh Sách Sách";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Danh Sách Sách</h2>
        <p class="page-description">Dữ liệu lấy từ database qua luồng: Controller → Service → Repository (AsNoTracking) → DbContext</p>
    </div>
    <div>
        <a class="btn btn-secondary" asp-controller="Books" asp-action="Filter">Lọc Sách</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="success-box">@TempData["SuccessMessage"]</div>
}

<div class="info-box">
    <strong>Tổng số đầu sách:</strong> @Model.Count |
    <strong>Sách tồn kho thấp:</strong> @Model.Count(b => b.IsLowStock)
</div>

<table class="table">
    <thead>
        <tr>
            <th>Mã Sách</th>
            <th>Tên Sách</th>
            <th>Tác Giả</th>
            <th>Thể Loại</th>
            <th>Giá</th>
            <th>Tồn Kho</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.BookCode</td>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.GenreName</td>
                <td>@book.Price.ToString("N0") VNĐ</td>
                <td>
                    @if (book.Quantity == 0)
                    {
                        <span class="badge badge-danger">Hết hàng</span>
                    }
                    else if (book.IsLowStock)
                    {
                        <span class="badge badge-warning">@book.Quantity (thấp)</span>
                    }
                    else
                    {
                        <span class="badge badge-success">@book.Quantity</span>
                    }
                </td>
                <td>
                    <a asp-controller="Books" asp-action="Detail" asp-route-id="@book.Id">Chi tiết</a>
                </td>
            </tr>
        }
    </tbody>
</table>
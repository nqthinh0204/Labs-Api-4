@model BookStatsViewModel

@{
    ViewData["Title"] = "Book Inventory Stats";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Book Inventory Statistics</h2>

        <p class="page-description">
            This page provides an overview of the bookstore inventory status.
        </p>
    </div>

    <a class="btn btn-light" href="/Books">
        Back to Catalog
    </a>
</div>

<div class="stat-grid">

    <div class="stat-card">
        <div class="stat-number">@Model.TotalBooks</div>

        <div class="stat-label">
            Total Book Titles
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-number">@Model.TotalQuantity</div>

        <div class="stat-label">
            Total Quantity
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-number">
            @Model.TotalInventoryValueText
        </div>

        <div class="stat-label">
            Total Inventory Value
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-number text-danger">
            @Model.OutOfStockCount
        </div>

        <div class="stat-label">
            Out of Stock Books
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-number text-warning">
            @Model.LowStockCount
        </div>

        <div class="stat-label">
            Low Stock Books
        </div>
    </div>

</div>

<div class="info-panel">

    <h4>Inventory Evaluation</h4>

    @if (Model.OutOfStockCount > 0)
    {
        <p class="text-danger">
            Some books are currently out of stock and should be restocked soon.
        </p>
    }
    else if (Model.LowStockCount > 0)
    {
        <p class="text-warning">
            Some books are running low. Consider restocking soon.
        </p>
    }
    else
    {
        <p class="text-success">
            Current inventory status is stable.
        </p>
    }

</div>

<table class="table table-bordered mt-4">

    <tr>
        <th>Total Book Titles</th>
        <td>@Model.TotalBooks</td>
    </tr>

    <tr>
        <th>Total Quantity</th>
        <td>@Model.TotalQuantity</td>
    </tr>

    <tr>
        <th>Total Inventory Value</th>
        <td>@Model.TotalInventoryValueText</td>
    </tr>

    <tr>
        <th>Out of Stock Books</th>
        <td>@Model.OutOfStockCount</td>
    </tr>

    <tr>
        <th>Low Stock Books</th>
        <td>@Model.LowStockCount</td>
    </tr>

</table>
@{
    ViewData["Title"] = "Trang Chủ";
}

<div class="page-header">
    <div>
        <h2 class="page-title">@ViewData["AppName"]</h2>
        <p class="page-description">Hệ thống quản lý bán sách - Mini Bookstore Lab04</p>
    </div>
</div>

<div class="info-box">
    <strong>Liên hệ hỗ trợ:</strong> @ViewData["SupportEmail"]
</div>

<div class="product-grid">
    <div class="product-card">
        <h3>Danh Sách Sách</h3>
        <p class="product-meta">Xem toàn bộ sách lấy từ database qua luồng Controller → Service → Repository → DbContext</p>
        <div class="card-actions">
            <a class="btn" asp-controller="Books" asp-action="Index">Xem Sách</a>
        </div>
    </div>
    <div class="product-card">
        <h3>Thể Loại</h3>
        <p class="product-meta">Xem quan hệ One-to-Many: một thể loại có nhiều cuốn sách</p>
        <div class="card-actions">
            <a class="btn" asp-controller="Genres" asp-action="Index">Xem Thể Loại</a>
        </div>
    </div>
    <div class="product-card">
        <h3>Bán Sách</h3>
        <p class="product-meta">Tạo hóa đơn bán sách với Transaction: ghi Sale, SaleItem và trừ Quantity</p>
        <div class="card-actions">
            <a class="btn" asp-controller="Sales" asp-action="Create">Bán Sách</a>
        </div>
    </div>
    <div class="product-card">
        <h3>Data Health</h3>
        <p class="product-meta">Kiểm tra migration, seed data, Tracking và AsNoTracking</p>
        <div class="card-actions">
            <a class="btn" asp-controller="DataHealth" asp-action="Index">Kiểm Tra</a>
        </div>
    </div>
</div>
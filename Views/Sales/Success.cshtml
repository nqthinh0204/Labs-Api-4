@{
    ViewData["Title"] = "Thành Công";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Tạo Hóa Đơn Thành Công!</h2>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="success-box">@TempData["SuccessMessage"]</div>
}

<div style="margin-top:24px">
    <a class="btn" asp-controller="Sales" asp-action="History">Xem Lịch Sử Bán Hàng</a>
    <a class="btn btn-secondary" asp-controller="Books" asp-action="Index">Về Danh Sách Sách</a>
    <a class="btn btn-light" asp-controller="Sales" asp-action="Create">Bán Sách Tiếp</a>
</div>
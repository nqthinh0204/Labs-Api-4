<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mini Bookstore</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container header-content">
            <div class="brand">
                <a asp-controller="Home" asp-action="Index">Mini Bookstore</a>
            </div>
            <nav class="main-nav">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Books" asp-action="Index">Sách</a>
                <a asp-controller="Genres" asp-action="Index">Thể Loại</a>
                <a asp-controller="Books" asp-action="Filter">Lọc Sách</a>
                <a asp-controller="Sales" asp-action="Create">Bán Sách</a>
                <a asp-controller="Sales" asp-action="History">Lịch Sử</a>
                <a asp-controller="DataHealth" asp-action="Index">DataHealth</a>
            </nav>
        </div>
    </header>

    <main class="container main-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container footer-content">
            <span>&copy; 2025 - Mini Bookstore - Lab04</span>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>